# ============================================================================
# Maths Tasks — environment variables
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored and MUST NEVER be committed.
# ============================================================================

# ---- Public (safe to expose to the browser) --------------------------------
# Both are sent to the client bundle. NEXT_PUBLIC_ prefix is required for that.
# Project URL:  Supabase Dashboard → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Publishable / anon key (safe in the browser; RLS is what protects data).
# Dashboard → Project Settings → API Keys → "anon / public"
# (newer projects label this the "publishable" key, sb_publishable_...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Canonical site URL — used to build magic-link / invite redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Server-only SECRETS (NEVER prefix with NEXT_PUBLIC) --------------------
# Service-role / secret key. Bypasses RLS — full god-mode over the database.
# Used ONLY server-side (Route Handlers / Edge Functions) to create student
# accounts. If this ever reaches the browser, treat it as fully compromised
# and rotate it immediately. Dashboard → Project Settings → API Keys →
# "service_role" (or the "secret" key, sb_secret_...).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-OR-SECRET-KEY

# Resend API key — for reminder emails (Step 5). Server-side only.
# https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_KEY

# Email address reminders are sent FROM. Must be a Resend-verified domain/sender.
RESEND_FROM_EMAIL="Maths Tasks <homework@your-verified-domain.com>"

# ---- Rate limiting (Upstash Redis) — optional but recommended for prod -------
# Backs the distributed rate limiter (lib/rate-limit.ts) that throttles sign-in
# and student-creation. If BOTH are unset, rate limiting is DISABLED (the app
# still runs) — fine for local dev. Provision via Vercel Marketplace → Upstash,
# which sets these automatically, or copy them from the Upstash console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
